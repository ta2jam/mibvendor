{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mibvendor.io/schemas/data-release.v1.json",
  "title": "mibvendor immutable data release",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release_id", "created_at", "canonical_schema", "previous_release", "sources", "modules", "counts", "manifest_sha256"],
  "properties": {
    "schema_version": { "const": 1 },
    "release_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{2,99}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "canonical_schema": { "const": "mibvendor.canonical/1" },
    "previous_release": { "type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9.-]{2,99}$" },
    "sources": { "type": "array", "uniqueItems": true, "items": { "$ref": "source-snapshot.schema.json" } },
    "modules": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["definition_id", "canonical_sha256", "source_snapshot_id"],
        "properties": {
          "definition_id": { "type": "string", "pattern": "^module_[0-9a-f]{64}$" },
          "canonical_sha256": { "$ref": "#/$defs/sha256" },
          "source_snapshot_id": { "type": "string", "pattern": "^src_[0-9a-f]{64}$" }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources", "modules", "objects", "warnings", "errors"],
      "properties": {
        "sources": { "type": "integer", "minimum": 0 },
        "modules": { "type": "integer", "minimum": 0 },
        "objects": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 }
      }
    },
    "manifest_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
