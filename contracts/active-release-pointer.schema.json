{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mibvendor.io/schemas/active-release-pointer.v1.json",
  "title": "mibvendor mutable active release pointer",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "active_release", "previous_release", "activated_at", "reason"],
  "properties": {
    "schema_version": { "const": 1 },
    "active_release": { "$ref": "#/$defs/releaseId" },
    "previous_release": { "type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9.-]{2,99}$" },
    "activated_at": { "type": "string", "format": "date-time" },
    "reason": { "type": "string", "enum": ["promotion", "rollback", "rights-revocation", "correction"] }
  },
  "$defs": {
    "releaseId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{2,99}$" }
  }
}
