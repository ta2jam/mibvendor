{
  "name": "mibvendor",
  "version": "0.1.0-alpha.3",
  "private": true,
  "description": "Research foundation and task prototype for a source-aware MIB browser and API",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "check": "node scripts/check-repository.mjs",
    "check:rights": "python3 docs/research/rights/validate_rights_matrix.py",
    "check:parser-results": "python3 experiments/parser-bakeoff/scripts/validate_results.py experiments/parser-bakeoff/results/2026-07-13-macos-arm64",
    "test": "node --test tests/*.test.mjs",
    "verify": "npm run check && npm run check:rights && npm run check:parser-results && npm test",
    "benchmark:prototype": "node scripts/benchmark-walk-prototype.mjs 50000",
    "serve:prototype": "python3 -m http.server 4173 --directory prototype",
    "serve:api-mock": "node scripts/phase0-api-mock.mjs"
  },
  "engines": {
    "node": ">=20.9"
  }
}
